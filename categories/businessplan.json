{
  "category_name": {
    "de": "Businessplan",
    "en": "Business Plan",
    "fr": "Plan d'affaires",
    "es": "Plan de negocios"
  },
  "fields": [
    {
      "key": "business_idea",
      "type": "entry",
      "label": {
        "de": "Geschaeftsidee/Name",
        "en": "Business Idea/Name",
        "fr": "Idee d'entreprise/Nom",
        "es": "Idea de negocio/Nombre"
      },
      "default": {
        "de": "Meine Geschaeftsidee",
        "en": "My Business Idea",
        "fr": "Mon idee d'entreprise",
        "es": "Mi idea de negocio"
      }
    },
    {
      "key": "value_proposition",
      "type": "text",
      "label": {
        "de": "Werteversprechen (Unique Selling Point)",
        "en": "Value Proposition (USP)",
        "fr": "Proposition de valeur (USP)",
        "es": "Proposicion de valor (USP)"
      },
      "default": {
        "de": "Was unterscheidet uns von der Konkurrenz?",
        "en": "What sets us apart from competitors?",
        "fr": "Qu'est-ce qui nous distingue des concurrents?",
        "es": "Que nos distingue de la competencia?"
      }
    },
    {
      "key": "target_market",
      "type": "text",
      "label": {
        "de": "Zielmarkt",
        "en": "Target Market",
        "fr": "Marche cible",
        "es": "Mercado objetivo"
      },
      "default": {
        "de": "Groesse, Segment, Geografie, Wachstum",
        "en": "Size, Segment, Geography, Growth",
        "fr": "Taille, Segment, Geographie, Croissance",
        "es": "Tamano, Segmento, Geografia, Crecimiento"
      }
    },
    {
      "key": "revenue_model",
      "type": "combobox",
      "label": {
        "de": "Revenue-Modell",
        "en": "Revenue Model",
        "fr": "Modele de revenus",
        "es": "Modelo de ingresos"
      },
      "options": {
        "de": ["Subscription/Abo", "One-Time Purchase", "Freemium", "Marketplace", "Advertising", "Licensing"],
        "en": ["Subscription", "One-Time Purchase", "Freemium", "Marketplace", "Advertising", "Licensing"],
        "fr": ["Abonnement", "Achat unique", "Freemium", "Marche", "Publicite", "Octroi de licence"],
        "es": ["Suscripcion", "Compra unica", "Freemium", "Mercado", "Publicidad", "Licencia"]
      },
      "default": {
        "de": "Subscription/Abo",
        "en": "Subscription",
        "fr": "Abonnement",
        "es": "Suscripcion"
      }
    },
    {
      "key": "pricing_strategy",
      "type": "entry",
      "label": {
        "de": "Preisstufen/Tiers",
        "en": "Pricing Tiers",
        "fr": "Niveaux de prix",
        "es": "Niveles de precios"
      },
      "default": {
        "de": "Basic / Professional / Enterprise",
        "en": "Basic / Professional / Enterprise",
        "fr": "Basique / Professionnel / Entreprise",
        "es": "Basico / Profesional / Empresarial"
      }
    },
    {
      "key": "competitive_analysis",
      "type": "text",
      "label": {
        "de": "Konkurrenzanalyse",
        "en": "Competitive Analysis",
        "fr": "Analyse concurrentielle",
        "es": "Analisis competitivo"
      },
      "default": {
        "de": "Direkte & indirekte Konkurrenten, Staerken, Schwaechen",
        "en": "Direct & indirect competitors, strengths, weaknesses",
        "fr": "Concurrents directs et indirects, points forts, points faibles",
        "es": "Competidores directos e indirectos, fortalezas, debilidades"
      }
    },
    {
      "key": "funding_needs",
      "type": "entry",
      "label": {
        "de": "Finanzierungsbedarf",
        "en": "Funding Needs",
        "fr": "Besoins de financement",
        "es": "Necesidades de financiamiento"
      },
      "default": {
        "de": "Hoehe, Zweck, Zeitrahmen",
        "en": "Amount, Purpose, Timeline",
        "fr": "Montant, But, Calendrier",
        "es": "Monto, Proposito, Cronograma"
      }
    },
    {
      "key": "financial_projections",
      "type": "combobox",
      "label": {
        "de": "Finanzielle Prognosen",
        "en": "Financial Projections",
        "fr": "Projections financieres",
        "es": "Proyecciones financieras"
      },
      "options": {
        "de": ["1-3 Jahre", "3-5 Jahre", "5-10 Jahre", "Break-even Analyse"],
        "en": ["1-3 years", "3-5 years", "5-10 years", "Break-even Analysis"],
        "fr": ["1-3 ans", "3-5 ans", "5-10 ans", "Analyse du seuil de rentabilite"],
        "es": ["1-3 anos", "3-5 anos", "5-10 anos", "Analisis de equilibrio"]
      },
      "default": {
        "de": "3-5 Jahre",
        "en": "3-5 years",
        "fr": "3-5 ans",
        "es": "3-5 anos"
      }
    },
    {
      "key": "team",
      "type": "text",
      "label": {
        "de": "Gruenderteam",
        "en": "Founding Team",
        "fr": "Equipe fondatrice",
        "es": "Equipo fundador"
      },
      "default": {
        "de": "Rollen, Erfahrung, Expertise",
        "en": "Roles, Experience, Expertise",
        "fr": "Roles, Experience, Expertise",
        "es": "Funciones, Experiencia, Experiencia"
      }
    },
    {
      "key": "key_risks",
      "type": "text",
      "label": {
        "de": "Schluesselrisiken",
        "en": "Key Risks",
        "fr": "Risques cles",
        "es": "Riesgos clave"
      },
      "default": {
        "de": "Marktrisiko, Technologierisiko, Teamrisiko, etc.",
        "en": "Market risk, technology risk, team risk, etc.",
        "fr": "Risque de marche, risque technologique, risque d'equipe, etc.",
        "es": "Riesgo de mercado, riesgo tecnologico, riesgo de equipo, etc."
      }
    }
  ],
