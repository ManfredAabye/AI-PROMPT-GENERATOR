{
  "category_name": {
    "de": "Automatisierung / Workflow",
    "en": "Automation / Workflow",
    "fr": "Automatisation / Flux de travail",
    "es": "Automatizacion / Flujo de trabajo"
  },
  "fields": [
    {
      "key": "process_name",
      "type": "entry",
      "label": {
        "de": "Prozessname",
        "en": "Process Name",
        "fr": "Nom du processus",
        "es": "Nombre del proceso"
      },
      "default": {
        "de": "Mein Prozess",
        "en": "My Process",
        "fr": "Mon processus",
        "es": "Mi proceso"
      }
    },
    {
      "key": "trigger",
      "type": "entry",
      "label": {
        "de": "Trigger/Start-Bedingung",
        "en": "Trigger/Start Condition",
        "fr": "Declencheur/Condition de demarrage",
        "es": "Disparador/Condicion de inicio"
      },
      "default": {
        "de": "E-Mail erhielt, Zeit-Event, Datei-Upload",
        "en": "Email received, time event, file upload",
        "fr": "E-mail recu, evenement temporel, televersement",
        "es": "Email recibido, evento de tiempo, carga de archivo"
      }
    },
    {
      "key": "input_data",
      "type": "text",
      "label": {
        "de": "Eingabedaten",
        "en": "Input Data",
        "fr": "Donnees d'entree",
        "es": "Datos de entrada"
      },
      "default": {
        "de": "Was wird als Input erwartet?",
        "en": "What is expected as input?",
        "fr": "Quelles entrees sont attendues?",
        "es": "Que se espera como entrada?"
      }
    },
    {
      "key": "processing_steps",
      "type": "text",
      "label": {
        "de": "Verarbeitungsschritte",
        "en": "Processing Steps",
        "fr": "Etapes de traitement",
        "es": "Pasos de procesamiento"
      },
      "default": {
        "de": "1. Validierung, 2. Transformation, 3. Anreicherung",
        "en": "1. Validation, 2. Transform, 3. Enrich",
        "fr": "1. Validation, 2. Transformation, 3. Enrichissement",
        "es": "1. Validacion, 2. Transformacion, 3. Enriquecimiento"
      }
    },
    {
      "key": "tools_and_apis",
      "type": "entry",
      "label": {
        "de": "Tools / APIs / Services",
        "en": "Tools / APIs / Services",
        "fr": "Outils / APIs / Services",
        "es": "Herramientas / APIs / Servicios"
      },
      "default": {
        "de": "Zapier, Make, IFTTT, Custom APIs",
        "en": "Zapier, Make, IFTTT, Custom APIs",
        "fr": "Zapier, Make, IFTTT, APIs personnalisees",
        "es": "Zapier, Make, IFTTT, APIs personalizadas"
      }
    },
    {
      "key": "output_action",
      "type": "entry",
      "label": {
        "de": "Output / Aktion",
        "en": "Output / Action",
        "fr": "Sortie / Action",
        "es": "Salida / Accion"
      },
      "default": {
        "de": "E-Mail senden, Datei speichern, DB aktualisieren",
        "en": "Send email, save file, update database",
        "fr": "Envoyer e-mail, enregistrer fichier, mise a jour BD",
        "es": "Enviar email, guardar archivo, actualizar BD"
      }
    },
    {
      "key": "error_handling",
      "type": "combobox",
      "label": {
        "de": "Fehlerbehandlung",
        "en": "Error Handling",
        "fr": "Gestion des erreurs",
        "es": "Manejo de errores"
      },
      "options": {
        "de": ["Stoppe und benachrichtige", "Versuche erneut", "Log und continue", "Fallback-Aktion"],
        "en": ["Stop and notify", "Retry", "Log and continue", "Fallback action"],
        "fr": ["Arreter et notifier", "Reessayer", "Enregistrer et continuer", "Action de repli"],
        "es": ["Detener y notificar", "Reintentar", "Registrar y continuar", "Accion de respaldo"]
      },
      "default": {
        "de": "Stoppe und benachrichtige",
        "en": "Stop and notify",
        "fr": "Arreter et notifier",
        "es": "Detener y notificar"
      }
    },
    {
      "key": "logging_and_monitoring",
      "type": "entry",
      "label": {
        "de": "Logging / Monitoring",
        "en": "Logging / Monitoring",
        "fr": "Journalisation / Surveillance",
        "es": "Registro / Monitoreo"
      },
      "default": {
        "de": "Was sollte geloggt/ueberwacht werden?",
        "en": "What should be logged/monitored?",
        "fr": "Qu'est-ce qui doit etre enregistre/surveille?",
        "es": "Que debe ser registrado/monitoreado?"
      }
    },
    {
      "key": "workflow_goal",
      "type": "entry",
      "label": {
        "de": "Ziel des Workflows",
        "en": "Workflow Goal",
        "fr": "Objectif du workflow",
        "es": "Objetivo del flujo"
      },
      "default": {
        "de": "Was soll am Ende effizienter, schneller oder sicherer sein?",
        "en": "What should become more efficient, faster or safer?",
        "fr": "Qu'est-ce qui doit devenir plus efficace, plus rapide ou plus sur ?",
        "es": "Que debe ser mas eficiente, rapido o seguro al final?"
      }
    },
    {
      "key": "execution_frequency",
      "type": "combobox",
      "label": {
        "de": "Ausfuehrungsfrequenz",
        "en": "Execution Frequency",
        "fr": "Frequence d'execution",
        "es": "Frecuencia de ejecucion"
      },
      "options": {
        "de": ["Echtzeit", "Mehrmals pro Stunde", "Taeglich", "Woechentlich", "Monatlich", "On-Demand"],
        "en": ["Real-time", "Multiple times per hour", "Daily", "Weekly", "Monthly", "On-demand"],
        "fr": ["Temps reel", "Plusieurs fois par heure", "Quotidien", "Hebdomadaire", "Mensuel", "A la demande"],
        "es": ["Tiempo real", "Varias veces por hora", "Diario", "Semanal", "Mensual", "Bajo demanda"]
      },
      "default": {
        "de": "Taeglich",
        "en": "Daily",
        "fr": "Quotidien",
        "es": "Diario"
      }
    },
    {
      "key": "approvals_and_handoffs",
      "type": "text",
      "label": {
        "de": "Freigaben / Uebergaben",
        "en": "Approvals / Handoffs",
        "fr": "Approbations / Passages de relais",
        "es": "Aprobaciones / Transferencias"
      },
      "default": {
        "de": "Welche manuellen Pruefungen, Eskalationen oder Team-Uebergaben gibt es?",
        "en": "Which manual reviews, escalations or team handoffs are needed?",
        "fr": "Quelles validations manuelles, escalades ou transmissions d'equipe sont necessaires ?",
        "es": "Que revisiones manuales, escalaciones o transferencias de equipo se necesitan?"
      }
    },
    {
      "key": "success_metrics",
      "type": "entry",
      "label": {
        "de": "Erfolgsmetriken",
        "en": "Success Metrics",
        "fr": "Metriques de succes",
        "es": "Metricas de exito"
      },
      "default": {
        "de": "Zeitersparnis, Fehlerquote, SLA, Durchlaufzeit",
        "en": "Time saved, error rate, SLA, cycle time",
        "fr": "Temps gagne, taux d'erreur, SLA, temps de cycle",
        "es": "Tiempo ahorrado, tasa de error, SLA, tiempo de ciclo"
      }
    }
  ],
