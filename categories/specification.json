      "fr": "Exigences obligatoires: {must_haves}",
      "es": "Requisitos obligatorios: {must_haves}"
    },
    "spec_5": {
      "de": "Kann-Anforderungen: {nice_to_have}",
      "en": "Nice-to-Haves: {nice_to_have}",
      "fr": "Exigences optionnelles: {nice_to_have}",
      "es": "Requisitos opcionales: {nice_to_have}"
    },
    "spec_6": {
      "de": "Akzeptanzkriterien: {acceptance_criteria}",
      "en": "Acceptance Criteria: {acceptance_criteria}",
      "fr": "Criteres d'acceptation: {acceptance_criteria}",
      "es": "Criterios de aceptacion: {acceptance_criteria}"
    },
    "spec_7": {
      "de": "Abhaengigkeiten: {dependencies}",
      "en": "Dependencies: {dependencies}",
      "fr": "Dependances: {dependencies}",
      "es": "Dependencias: {dependencies}"
    },
    "spec_8": {
      "de": "Einschraenkungen: {constraints}",
      "en": "Constraints: {constraints}",
      "fr": "Contraintes: {constraints}",
      "es": "Restricciones: {constraints}"
    },
    "spec_9": {
      "de": "Business-Ziel: {business_goal}",
      "en": "Business Goal: {business_goal}",
      "fr": "Objectif business: {business_goal}",
      "es": "Objetivo de negocio: {business_goal}"
    },
    "spec_10": {
      "de": "Erfolgsmetriken: {success_metrics}",
      "en": "Success Metrics: {success_metrics}",
      "fr": "Metriques de succes: {success_metrics}",
      "es": "Metricas de exito: {success_metrics}"
    },
    "spec_11": {
      "de": "Nicht-Ziele: {non_goals}",
      "en": "Non-Goals: {non_goals}",
      "fr": "Non-objectifs: {non_goals}",
      "es": "No objetivos: {non_goals}"
    },
    "spec_12": {
      "de": "Release-Prioritaet: {release_priority}",
      "en": "Release Priority: {release_priority}",
      "fr": "Priorite de livraison: {release_priority}",
      "es": "Prioridad de lanzamiento: {release_priority}"
    }
  }
