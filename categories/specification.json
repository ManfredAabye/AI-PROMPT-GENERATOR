{
  "category_name": {
    "de": "Produktanforderungen",
    "en": "Product Specification",
    "fr": "Specification produit",
    "es": "Especificacion de producto"
  },
  "fields": [
    {
      "key": "product_name",
      "type": "entry",
      "label": {
        "de": "Produkt/Feature Name",
        "en": "Product/Feature Name",
        "fr": "Nom du produit/feature",
        "es": "Nombre del producto/feature"
      },
      "default": {
        "de": "Neues Feature",
        "en": "New Feature",
        "fr": "Nouvelle feature",
        "es": "Nueva feature"
      }
    },
    {
      "key": "description",
      "type": "text",
      "label": {
        "de": "Kurzbeschreibung",
        "en": "Brief Description",
        "fr": "Breve description",
        "es": "Breve descripcion"
      },
      "default": {
        "de": "Was soll das Produkt/Feature tun?",
        "en": "What should the product/feature do?",
        "fr": "Que doit faire le produit/feature?",
        "es": "Que debe hacer el producto/feature?"
      }
    },
    {
      "key": "user_persona",
      "type": "entry",
      "label": {
        "de": "Benutzer/Persona",
        "en": "User/Persona",
        "fr": "Utilisateur/Persona",
        "es": "Usuario/Persona"
      },
      "default": {
        "de": "Beispiel-Nutzer",
        "en": "Example User",
        "fr": "Utilisateur exemple",
        "es": "Usuario ejemplo"
      }
    },
    {
      "key": "must_haves",
      "type": "text",
      "label": {
        "de": "Muss-Anforderungen (Must-Have)",
        "en": "Must-Have Requirements",
        "fr": "Exigences obligatoires",
        "es": "Requisitos obligatorios"
      },
      "default": {
        "de": "Funktionen die auf keinen Fall fehlen duerfen",
        "en": "Features that are absolutely essential",
        "fr": "Fonctionnalites indispensables",
        "es": "Funcionalidades indispensables"
      }
    },
    {
      "key": "nice_to_have",
      "type": "text",
      "label": {
        "de": "Kann-Anforderungen (Nice-to-Have)",
        "en": "Nice-to-Have Requirements",
        "fr": "Exigences optionnelles",
        "es": "Requisitos opcionales"
      },
      "default": {
        "de": "Zusaetzliche Features die den Wert erhoehen",
        "en": "Additional features that add value",
        "fr": "Fonctionnalites supplementaires utiles",
        "es": "Funcionalidades adicionales utiles"
      }
    },
    {
      "key": "acceptance_criteria",
      "type": "text",
      "label": {
        "de": "Akzeptanzkriterien",
        "en": "Acceptance Criteria",
        "fr": "Criteres d'acceptation",
        "es": "Criterios de aceptacion"
      },
      "default": {
        "de": "Wie erkenne ich, dass es fertig ist?",
        "en": "How do I know it's done?",
        "fr": "Comment savoir que c'est fini?",
        "es": "Como se que esta hecho?"
      }
    },
    {
      "key": "dependencies",
      "type": "entry",
      "label": {
        "de": "Abhaengigkeiten",
        "en": "Dependencies",
        "fr": "Dependances",
        "es": "Dependencias"
      },
      "default": {
        "de": "Andere Features/Services die noetig sind",
        "en": "Other features/services required",
        "fr": "Autres features/services requis",
        "es": "Otras features/servicios requeridos"
      }
    },
    {
      "key": "constraints",
      "type": "entry",
      "label": {
        "de": "Einschraenkungen/Limits",
        "en": "Constraints/Limits",
        "fr": "Contraintes/Limites",
        "es": "Restricciones/Limites"
      },
      "default": {
        "de": "Budget, Zeit, technische Limits",
        "en": "Budget, timeline, technical limits",
        "fr": "Budget, calendrier, limites techniques",
        "es": "Presupuesto, cronograma, limites tecnicos"
      }
    },
    {
      "key": "business_goal",
      "type": "entry",
      "label": {
        "de": "Business-Ziel",
        "en": "Business Goal",
        "fr": "Objectif business",
        "es": "Objetivo de negocio"
      },
      "default": {
        "de": "Welches messbare Geschaeftsziel soll das Feature unterstuetzen?",
        "en": "Which measurable business goal should the feature support?",
        "fr": "Quel objectif business mesurable la fonctionnalite doit-elle soutenir ?",
        "es": "Que objetivo de negocio medible debe apoyar la funcionalidad?"
      }
    },
    {
      "key": "success_metrics",
      "type": "text",
      "label": {
        "de": "Erfolgsmetriken",
        "en": "Success Metrics",
        "fr": "Metriques de succes",
        "es": "Metricas de exito"
      },
      "default": {
        "de": "Adoption, Conversion, Bearbeitungszeit, Zufriedenheit, Fehlerquote",
        "en": "Adoption, conversion, processing time, satisfaction, error rate",
        "fr": "Adoption, conversion, temps de traitement, satisfaction, taux d'erreur",
        "es": "Adopcion, conversion, tiempo de proceso, satisfaccion, tasa de error"
      }
    },
    {
      "key": "non_goals",
      "type": "text",
      "label": {
        "de": "Nicht-Ziele",
        "en": "Non-Goals",
        "fr": "Non-objectifs",
        "es": "No objetivos"
      },
      "default": {
        "de": "Was gehoert explizit nicht in diese Umsetzung?",
        "en": "What is explicitly out of scope for this implementation?",
        "fr": "Qu'est-ce qui est explicitement hors du perimetre de cette implementation ?",
        "es": "Que queda explicitamente fuera del alcance de esta implementacion?"
      }
    },
    {
      "key": "release_priority",
      "type": "combobox",
      "label": {
        "de": "Release-Prioritaet",
        "en": "Release Priority",
        "fr": "Priorite de livraison",
        "es": "Prioridad de lanzamiento"
      },
      "options": {
        "de": ["Sofort", "Naechster Sprint", "Mittelfristig", "Backlog"],
        "en": ["Immediate", "Next sprint", "Mid-term", "Backlog"],
        "fr": ["Immediate", "Prochain sprint", "Moyen terme", "Backlog"],
        "es": ["Inmediata", "Proximo sprint", "Medio plazo", "Backlog"]
      },
      "default": {
        "de": "Naechster Sprint",
        "en": "Next sprint",
        "fr": "Prochain sprint",
        "es": "Proximo sprint"
      }
    }
  ],
  "prompts": {
    "spec_1": {
      "de": "Feature: {product_name}",
      "en": "Feature: {product_name}",
      "fr": "Feature: {product_name}",
      "es": "Feature: {product_name}"
    },
    "spec_2": {
      "de": "Beschreibung: {description}",
      "en": "Description: {description}",
      "fr": "Description: {description}",
      "es": "Descripcion: {description}"
    },
    "spec_3": {
