{
  "category_name": {
    "de": "Architektur",
    "en": "Architecture",
    "fr": "Architecture",
    "es": "Arquitectura"
  },
  "fields": [
    {
      "key": "style",
      "type": "combobox",
      "label": {
        "de": "Architekturstil",
        "en": "Architecture Style",
        "fr": "Style architectural",
        "es": "Estilo arquitectonico"
      },
      "options": {
        "de": ["modern", "klassisch", "minimalistisch", "rustikal", "industriell", "viktorianisch"],
        "en": ["modern", "classic", "minimalist", "rustic", "industrial", "victorian"],
        "fr": ["moderne", "classique", "minimaliste", "rustique", "industriel", "victorien"],
        "es": ["moderno", "clasico", "minimalista", "rustico", "industrial", "victoriano"]
      },
      "default": {
        "de": "modern",
        "en": "modern",
        "fr": "moderne",
        "es": "moderno"
      }
    },
    {
      "key": "material",
      "type": "combobox",
      "label": {
        "de": "Fassadenmaterial",
        "en": "Facade Material",
        "fr": "Materiau de facade",
        "es": "Material de fachada"
      },
      "options": {
        "de": ["Putz", "Holz", "Backstein", "Stein", "Metall", "Glas"],
        "en": ["Plaster", "Wood", "Brick", "Stone", "Metal", "Glass"],
        "fr": ["Enduit", "Bois", "Brique", "Pierre", "Metal", "Verre"],
        "es": ["Revoque", "Madera", "Ladrillo", "Piedra", "Metal", "Vidrio"]
      },
      "default": {
        "de": "Putz",
        "en": "Plaster",
        "fr": "Enduit",
        "es": "Revoque"
      }
    },
    {
      "key": "color",
      "type": "entry",
      "label": {
        "de": "Hauptfarbe",
        "en": "Main Color",
        "fr": "Couleur principale",
        "es": "Color principal"
      },
      "default": {
        "de": "weiss",
        "en": "white",
        "fr": "blanc",
        "es": "blanco"
      }
    },
    {
      "key": "lighting",
      "type": "combobox",
      "label": {
        "de": "Beleuchtung",
        "en": "Lighting",
        "fr": "Eclairage",
        "es": "Iluminacion"
      },
      "options": {
        "de": ["Tageslicht", "Abendlicht", "Morgenlicht", "dramatisch", "Studio", "Nacht"],
        "en": ["Daylight", "Evening light", "Morning light", "Dramatic", "Studio", "Night"],
        "fr": ["Lumiere du jour", "Lumiere du soir", "Lumiere du matin", "Dramatique", "Studio", "Nuit"],
        "es": ["Luz diurna", "Luz de tarde", "Luz de manana", "Dramatico", "Estudio", "Noche"]
      },
      "default": {
        "de": "Tageslicht",
        "en": "Daylight",
        "fr": "Lumiere du jour",
        "es": "Luz diurna"
      }
    },
    {
      "key": "details",
      "type": "text",
      "label": {
        "de": "Details",
        "en": "Details",
        "fr": "Details",
        "es": "Detalles"
      },
      "default": {
        "de": "Vordach, Hausnummer, Briefkasten, Fensterlaeden",
        "en": "Canopy, house number, mailbox, shutters",
        "fr": "Auvent, numero de maison, boite aux lettres, volets",
        "es": "Tejadillo, numero de casa, buzon, persianas"
      }
    },
    {
      "key": "quality",
      "type": "combobox",
      "label": {
        "de": "Render-Qualitaet",
        "en": "Render Quality",
        "fr": "Qualite du rendu",
        "es": "Calidad de render"
      },
      "options": {
        "de": ["4K fotorealistisch", "8K ultra-realistisch", "Skizzen-Stil", "Aquarell", "Low-Poly"],
        "en": ["4K photorealistic", "8K ultra-realistic", "Sketch style", "Watercolor", "Low-poly"],
        "fr": ["4K photorealiste", "8K ultra-realiste", "Style croquis", "Aquarelle", "Low-poly"],
        "es": ["4K fotorrealista", "8K ultra-realista", "Estilo boceto", "Acuarela", "Low-poly"]
      },
      "default": {
        "de": "4K fotorealistisch",
        "en": "4K photorealistic",
        "fr": "4K photorealiste",
        "es": "4K fotorrealista"
      }
    },
    {
      "key": "building_type",
      "type": "entry",
      "label": {
        "de": "Gebaeudetyp",
        "en": "Building Type",
        "fr": "Type de batiment",
        "es": "Tipo de edificio"
      },
      "default": {
        "de": "Einfamilienhaus, Villa, Stadthaus oder Mehrfamilienhaus",
        "en": "Single-family home, villa, townhouse or apartment building",
        "fr": "Maison individuelle, villa, maison de ville ou immeuble",
        "es": "Casa unifamiliar, villa, casa urbana o edificio residencial"
      }
    },
    {
      "key": "environment_context",
      "type": "text",
      "label": {
        "de": "Umgebung / Kontext",
        "en": "Environment / Context",
        "fr": "Environnement / Contexte",
        "es": "Entorno / Contexto"
      },
      "default": {
        "de": "Stadt, Vorort, Hanglage, Waldnaehe, Wasserlage oder Nachbarschaft",
        "en": "City, suburb, hillside, forest edge, waterfront or neighborhood context",
        "fr": "Ville, banlieue, terrain en pente, lisiere de foret, bord de l'eau ou voisinage",
        "es": "Ciudad, suburbio, ladera, bosque, costa o contexto del vecindario"
      }
    },
    {
      "key": "camera_perspective",
      "type": "combobox",
      "label": {
        "de": "Kameraperspektive",
        "en": "Camera Perspective",
        "fr": "Perspective camera",
        "es": "Perspectiva de camara"
      },
      "options": {
        "de": ["Frontansicht", "Dreiviertelansicht", "Vogelperspektive", "Strassenansicht", "Nahaufnahme Eingang"],
        "en": ["Front view", "Three-quarter view", "Bird's-eye view", "Street view", "Entrance close-up"],
        "fr": ["Vue de face", "Vue trois-quarts", "Vue plongeante", "Vue rue", "Gros plan entree"],
        "es": ["Vista frontal", "Vista tres cuartos", "Vista aerea", "Vista de calle", "Primer plano de entrada"]
      },
      "default": {
        "de": "Dreiviertelansicht",
        "en": "Three-quarter view",
        "fr": "Vue trois-quarts",
        "es": "Vista tres cuartos"
      }
    },
    {
      "key": "landscaping",
      "type": "entry",
      "label": {
        "de": "Aussenbereich / Landscaping",
        "en": "Landscaping",
        "fr": "Amenagement exterieur",
        "es": "Paisajismo"
      },
      "default": {
        "de": "Garten, Einfahrt, Wege, Bepflanzung, Zaun oder Pool",
        "en": "Garden, driveway, paths, planting, fence or pool",
        "fr": "Jardin, allee, chemins, plantations, cloture ou piscine",
        "es": "Jardin, entrada, senderos, plantacion, valla o piscina"
      }
    }
  ],
