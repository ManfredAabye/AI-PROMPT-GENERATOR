        "fr": "Contexte / Scene",
        "es": "Contexto / Escena"
      },
      "default": {
        "de": "Wo befindet sich das Motiv und was passiert in der Szene?",
        "en": "Where is the subject and what is happening in the scene?",
        "fr": "Ou se trouve le sujet et que se passe-t-il dans la scene ?",
        "es": "Donde se encuentra el sujeto y que ocurre en la escena?"
      }
    },
    {
      "key": "usage_purpose",
      "type": "entry",
      "label": {
        "de": "Verwendungszweck",
        "en": "Usage Purpose",
        "fr": "Usage prevu",
        "es": "Uso previsto"
      },
      "default": {
        "de": "Website, Produktseite, Social Media, Portfolio oder Praesentation",
        "en": "Website, product page, social media, portfolio or presentation",
        "fr": "Site web, fiche produit, reseaux sociaux, portfolio ou presentation",
        "es": "Sitio web, pagina de producto, redes sociales, portfolio o presentacion"
      }
    },
    {
      "key": "negative_details",
      "type": "entry",
      "label": {
        "de": "Zu vermeiden",
        "en": "Avoid",
        "fr": "A eviter",
        "es": "Evitar"
      },
      "default": {
        "de": "Keine Unschaerfe, keine Ueberbelichtung, keine stoerenden Objekte",
        "en": "No blur, no overexposure, no distracting objects",
        "fr": "Pas de flou, pas de surexposition, pas d'objets distrayants",
        "es": "Sin desenfoque, sin sobreexposicion, sin objetos distractores"
      }
