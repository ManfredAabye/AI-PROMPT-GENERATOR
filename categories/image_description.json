        "fr": "Ratio d'image",
        "es": "Relacion de aspecto"
      },
      "options": {
        "de": ["1:1", "4:5", "16:9", "3:2", "9:16"],
        "en": ["1:1", "4:5", "16:9", "3:2", "9:16"],
        "fr": ["1:1", "4:5", "16:9", "3:2", "9:16"],
        "es": ["1:1", "4:5", "16:9", "3:2", "9:16"]
      },
      "default": {
        "de": "16:9",
        "en": "16:9",
        "fr": "16:9",
        "es": "16:9"
      }
    },
    {
      "key": "subject_context",
      "type": "text",
      "label": {
        "de": "Kontext / Szene",
