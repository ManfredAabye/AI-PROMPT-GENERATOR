        "en": "Main Subject",
        "fr": "Sujet principal",
        "es": "Motivo principal"
      },
      "default": {
        "de": "Hausfassade",
        "en": "House facade",
        "fr": "Facade de maison",
        "es": "Fachada de casa"
      }
    },
    {
      "key": "style",
      "type": "combobox",
      "label": {
