    "r1": {
      "de": "1. Erstelle einen {plan_label} mit Fruehstueck, Mittagessen und Abendessen sowie optionalen Snacks.",
      "en": "1. Create a {plan_label} with breakfast, lunch, dinner and optional snacks.",
      "fr": "1. Cree un {plan_label} avec petit-dejeuner, dejeuner, diner et collations optionnelles.",
      "es": "1. Crea un {plan_label} con desayuno, almuerzo, cena y snacks opcionales."
    },
    "r2": {
      "de": "2. Die Gerichte sollen einfach zuzubereiten sein und alltagstauglich bleiben.",
      "en": "2. Meals should be simple to prepare and practical for daily life.",
      "fr": "2. Les repas doivent etre simples a preparer et adaptes au quotidien.",
      "es": "2. Las comidas deben ser faciles de preparar y practicas para el dia a dia."
    },
    "r3": {
      "de": "3. Beruecksichtige folgende Haushaltsgeraete bei der Zubereitung:",
      "en": "3. Consider the following kitchen appliances during preparation:",
      "fr": "3. Tenez compte des appareils de cuisine suivants lors de la preparation :",
      "es": "3. Considera los siguientes electrodomesticos en la preparacion:"
    },
    "r4": {
      "de": "4. Plane {meals_per_day} Mahlzeiten pro Tag innerhalb eines {budget_level}en Budgets.",
      "en": "4. Plan {meals_per_day} meals per day within a {budget_level} budget.",
      "fr": "4. Planifiez {meals_per_day} repas par jour dans un budget {budget_level}.",
      "es": "4. Planifica {meals_per_day} comidas por dia dentro de un presupuesto {budget_level}."
    },
    "mealprep": {
      "de": "5. Integriere Gerichte, die sich gut vorbereiten und lagern lassen (Meal Prep), unter Beruecksichtigung von:\n   - Lagerungsmoeglichkeiten: {storage}",
      "en": "5. Include meal-prep friendly dishes with storage guidance:\n   - Storage options: {storage}",
      "fr": "5. Integrez des plats adaptes au meal prep avec consignes de stockage :\n   - Options de stockage : {storage}",
      "es": "5. Incluye platos aptos para meal prep con guia de almacenamiento:\n   - Opciones de almacenamiento: {storage}"
    },
    "r5": {
      "de": "6. Achte auf eine ausgewogene Naehrstoffverteilung (Eiweiss, gesunde Fette, komplexe Kohlenhydrate).",
      "en": "6. Ensure balanced macronutrients (protein, healthy fats, complex carbs).",
      "fr": "6. Assurez une repartition equilibree des macronutriments (proteines, bonnes graisses, glucides complexes).",
