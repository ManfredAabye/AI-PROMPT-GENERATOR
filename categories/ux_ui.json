      "es": "Componentes clave: {key_components}"
    },
    "ux_7": {
      "de": "Barrierefreiheit: {accessibility}",
      "en": "Accessibility: {accessibility}",
      "fr": "Accessibilite: {accessibility}",
      "es": "Accesibilidad: {accessibility}"
    },
    "ux_8": {
      "de": "Responsive Breakpoints: {responsive_breakpoints}",
      "en": "Responsive Breakpoints: {responsive_breakpoints}",
      "fr": "Points de rupture: {responsive_breakpoints}",
      "es": "Puntos de ruptura: {responsive_breakpoints}"
    },
    "ux_9": {
      "de": "Mikrokopie/Tonfall: {microcopy_tone}",
      "en": "Microcopy/Tone: {microcopy_tone}",
